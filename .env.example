# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority

# IEX Cloud API key (for stock data)
IEX_CLOUD_API_KEY=pk_your_api_key_here

# New York Times API key (for news headlines)
NYT_API_KEY=your_nyt_api_key_here

# MongoDB connection string for REST API server
MONGO_DB_CONN_STRING=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
